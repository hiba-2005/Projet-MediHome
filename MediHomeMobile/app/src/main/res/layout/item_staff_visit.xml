<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="92dp"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_staff_visit_item"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="14dp">

    <TextView
        android:id="@+id/tvItemInitials"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="@drawable/bg_staff_patient_avatar_orange"
        android:gravity="center"
        android:text="FB"
        android:textColor="#FF7A00"
        android:textSize="15sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvItemPatientName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Fatima Bennani"
            android:textColor="#102A43"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvItemDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="25 Avr 2026 · 17:30"
            android:textColor="#7B8CA3"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/tvItemAddress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_staff_small_tag"
            android:paddingStart="8dp"
            android:paddingTop="4dp"
            android:paddingEnd="8dp"
            android:paddingBottom="4dp"
            android:text="📍 Marrakech"
            android:textColor="#4B6B92"
            android:textSize="10sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvItemStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_staff_status_planned"
        android:paddingStart="10dp"
        android:paddingTop="6dp"
        android:paddingEnd="10dp"
        android:paddingBottom="6dp"
        android:text="Planifiée"
        android:textColor="#FF8A00"
        android:textSize="10sp"
        android:textStyle="bold" />
</LinearLayout>
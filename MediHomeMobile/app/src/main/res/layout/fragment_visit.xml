<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#071B33"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ma Visite"
                android:textColor="#FFFFFF"
                android:textSize="26sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Suivi de votre rendez-vous à domicile"
                android:textColor="#B7C7D9"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- STATUS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvVisitStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_visit_chip_green"
                android:paddingStart="16dp"
                android:paddingTop="8dp"
                android:paddingEnd="16dp"
                android:paddingBottom="8dp"
                android:text="● Terminée"
                android:textColor="#00E0B8"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvVisitDateTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:background="@drawable/bg_visit_chip_dark"
                android:paddingStart="16dp"
                android:paddingTop="8dp"
                android:paddingEnd="16dp"
                android:paddingBottom="8dp"
                android:text="17 Avr 2026 · 09:45"
                android:textColor="#DCE8EF"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- MAIN CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_visit_main_card"
            android:orientation="vertical"
            android:padding="22dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvVisitTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Consultation"
                        android:textColor="#FFFFFF"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvVisitSubtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Visite à domicile · MediHome"
                        android:textColor="#B7C7D9"
                        android:textSize="13sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvVisitDone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_visit_done_badge"
                    android:paddingStart="16dp"
                    android:paddingTop="9dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="9dp"
                    android:text="✓ Effectuée"
                    android:textColor="#062A29"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- GRID INFOS -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:columnCount="2"
                android:rowCount="2">

                <LinearLayout style="@style/VisitInfoBox">
                    <TextView style="@style/VisitInfoIcon" android:text="🗓️" />
                    <TextView style="@style/VisitInfoLabel" android:text="DATE" />
                    <TextView android:id="@+id/tvVisitDate" style="@style/VisitInfoValue" android:text="17 Avr 2026" />
                </LinearLayout>

                <LinearLayout style="@style/VisitInfoBox">
                    <TextView style="@style/VisitInfoIcon" android:text="🕘" />
                    <TextView style="@style/VisitInfoLabel" android:text="HEURE" />
                    <TextView android:id="@+id/tvVisitTime" style="@style/VisitInfoValue" android:text="09:45" />
                </LinearLayout>

                <LinearLayout style="@style/VisitInfoBox">
                    <TextView style="@style/VisitInfoIcon" android:text="🩺" />
                    <TextView style="@style/VisitInfoLabel" android:text="TYPE" />
                    <TextView android:id="@+id/tvVisitType" style="@style/VisitInfoValue" android:text="Consultation" />
                </LinearLayout>

                <LinearLayout style="@style/VisitInfoBox">
                    <TextView style="@style/VisitInfoIcon" android:text="⏱️" />
                    <TextView style="@style/VisitInfoLabel" android:text="DURÉE" />
                    <TextView android:id="@+id/tvVisitDuration" style="@style/VisitInfoValue" android:text="Effectuée" />
                </LinearLayout>

            </GridLayout>
        </LinearLayout>

        <!-- PERSONNEL -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:text="PERSONNEL MÉDICAL"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="95dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_visit_staff_card"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="18dp">

            <TextView
                android:id="@+id/tvStaffInitials"
                android:layout_width="58dp"
                android:layout_height="58dp"
                android:background="@drawable/bg_visit_staff_avatar"
                android:gravity="center"
                android:text="SK"
                android:textColor="#071B33"
                android:textSize="19sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvStaffName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sara Karimi"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvStaffSpeciality"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Médecin généraliste"
                    android:textColor="#B7C7D9"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tvStaffTag"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_visit_staff_tag"
                    android:paddingStart="10dp"
                    android:paddingTop="4dp"
                    android:paddingEnd="10dp"
                    android:paddingBottom="4dp"
                    android:text="MediHome · Visite terminée"
                    android:textColor="#9CD5FF"
                    android:textSize="11sp" />
            </LinearLayout>

            <TextView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_visit_arrow"
                android:gravity="center"
                android:text="›"
                android:textColor="#FFFFFF"
                android:textSize="22sp" />
        </LinearLayout>

        <!-- ETAPES -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:text="ÉTAPES DE LA VISITE"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_visit_staff_card"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView style="@style/VisitStepText" android:text="✅   Planifiée                                      09:00" />
            <TextView style="@style/VisitStepText" android:text="✅   Confirmée                                  09:15" />
            <TextView style="@style/VisitStepText" android:text="✅   En route                                    09:30" />
            <TextView style="@style/VisitStepText" android:text="✅   Terminée                                   09:45" />
        </LinearLayout>

        <!-- MESSAGE -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_visit_message_card"
            android:orientation="horizontal"
            android:padding="18dp">

            <TextView
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/bg_visit_message_icon"
                android:gravity="center"
                android:text="✅"
                android:textSize="20sp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:text="Message important"
                    android:textColor="#00E0B8"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

                <TextView
                    android:id="@+id/tvImportantMessage"
                    android:text="Votre visite à domicile a été effectuée avec succès."
                    android:textColor="#DCE8EF"
                    android:textSize="13sp"
                    android:layout_marginTop="4dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />
            </LinearLayout>
        </LinearLayout>

        <!-- CONSEILS -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:text="CONSEILS AVANT LA VISITE"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView style="@style/VisitAdviceBox" android:text="⏰   Soyez présent 10 min avant l'heure prévue." />
        <TextView style="@style/VisitAdviceBox" android:text="📄   Préparez vos documents et ordonnances." />
        <TextView style="@style/VisitAdviceBox" android:text="📱   Gardez votre téléphone disponible." />

        <Button
            android:id="@+id/btnRefreshVisit"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="22dp"
            android:layout_marginBottom="24dp"
            android:background="@drawable/bg_visit_button"
            android:text="Actualiser la visite"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />

    </LinearLayout>
</ScrollView>